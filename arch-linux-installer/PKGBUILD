# Maintainer: sm-alfariz <sm.alfariz@example.com>
# Contributor: fendoz

pkgname=nocturne
pkgver=1.3.0
pkgrel=1
pkgdesc="Premium offline-first desktop music player with lyrics sync, visualizer, and 10-band EQ"
arch=('any')
url="https://github.com/sm-alfariz/fendoz-Nocturne-player"
license=('custom:MIT')
depends=(
  'python>=3.12'
  'python-pyside6'
  'python-pyside6-fluent-widgets'
  'python-pysidesix-frameless-window'
  'python-vlc'
  'python-mutagen'
  'python-numpy'
  'python-scipy'
  'python-pillow'
  'python-httpx'
  'python-darkdetect'
  'python-colorthief'
  'python-sounddevice'
  'vlc'
  'qt6-wayland'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-wheel'
)
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  python -m build --wheel --no-isolation
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

  mkdir -p "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/nocturne.desktop" << EOF
[Desktop Entry]
Name=Nocturne
Comment=Premium music player with lyrics and visualizer
Exec=python -m nocturne
Terminal=false
Type=Application
Categories=Audio;AudioVideo;Player;
EOF

  mkdir -p "$pkgdir/usr/share/pixmaps"
  install -Dm644 resource/icon.png "$pkgdir/usr/share/pixmaps/nocturne.png" 2>/dev/null || true
}
