# Maintainer: sm-alfariz <sm.alfariz@example.com>
# Contributor: fendoz

pkgname=nocturne
pkgver=1.3.0
pkgrel=1
pkgdesc="Premium offline-first desktop music player with lyrics sync, visualizer, and 10-band EQ"
arch=('x86_64')
url="https://github.com/sm-alfariz/fendoz-Nocturne-player"
license=('custom:MIT')
depends=(
  'vlc'
  'qt6-wayland'
  'pulseaudio'
)
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  pyinstaller --noconfirm --clean nocturne.spec
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 dist/nocturne "$pkgdir/usr/bin/nocturne"

  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/nocturne.desktop" << EOF
[Desktop Entry]
Name=Nocturne
Comment=Premium music player with lyrics and visualizer
Exec=/usr/bin/nocturne
Terminal=false
Type=Application
Categories=Audio;AudioVideo;Player;
EOF

  install -Dm644 resource/img/icon.png "$pkgdir/usr/share/pixmaps/nocturne.png"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
